# Manifiestos generados por cluster (se generan con los scripts)
clusters/*/manifests/
clusters/*/clife-tmp/

# Descargas temporales (usar artifacts/ que ya está comprimido)
downloads/

# Imágenes de contenedores (muy grandes para Git, transferir por scp)
